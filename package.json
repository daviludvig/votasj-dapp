{
  "name": "votasj",
  "version": "0.1.0",
  "private": true,
  "description": "VotaSJ: blockchain-backed participatory budgeting for Sao Jose/SC (UFSC INE5458 2026/1)",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy.js --network amoy",
    "lint": "npm run lint:sol && npm run lint:js && npm run lint:md",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:js": "eslint .",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore coverage"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "markdownlint-cli": "^0.48.0",
    "solhint": "^6.2.1"
  }
}
