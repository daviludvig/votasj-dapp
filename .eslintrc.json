{
  "root": true,
  "env": {
    "node": true,
    "mocha": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "prefer-const": "error",
    "eqeqeq": ["error", "smart"]
  },
  "ignorePatterns": ["node_modules/", "artifacts/", "cache/", "coverage/", "typechain-types/"]
}
